# Prefer an AWS IAM Identity Center (SSO) profile or temporary credentials.
AWS_PROFILE=your-profile
AWS_REGION=ap-northeast-1
CDK_DEPLOY_REGION=ap-northeast-1

# If you must use temporary access keys, keep them only in your local .env.
# AWS_ACCESS_KEY_ID=REPLACE_ME
# AWS_SECRET_ACCESS_KEY=REPLACE_ME
# AWS_SESSION_TOKEN=REPLACE_ME

SLACK_WEBHOOK_SECRET_NAME=finops/slack-webhook
SCHEDULE_TIMEZONE=Asia/Tokyo
SCHEDULE_EXPRESSION=cron(0 9 * * ? *)
SCHEDULE_ENABLED=false

# Existing AWS COST budget to relay to Slack immediately.
BUDGET_NAME=My Monthly Cost Budget
BUDGET_ALERT_THRESHOLDS=50,75,90
BUDGET_FORECAST_ALERT_THRESHOLD=90

BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-5
BEDROCK_REGION=ap-northeast-1

REPORT_LOOKBACK_DAYS=7
COST_METRIC=UnblendedCost
CREATE_ANOMALY_MONITOR=false

# Read-only FinOps investigation agent. It runs only for material cost increases.
FINOPS_INVESTIGATION_ENABLED=true
FINOPS_INVESTIGATION_MIN_CHANGE_USD=100
FINOPS_INVESTIGATION_MIN_CHANGE_PERCENT=20
FINOPS_INVESTIGATION_MAX_TARGETS=3
FINOPS_INVESTIGATION_MAX_TOOL_CALLS=6
FINOPS_INVESTIGATION_MAX_TURNS=4
